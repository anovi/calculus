{
  "name": "compio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src",
    "preview": "npm run build && wrangler dev",
    "test": "vitest run",
    "bench": "vitest bench src/benchmarks",
    "test:watch": "vitest",
    "grammar": "lezer-generator ./src/language/baseline/compio-language.grammar -o ./src/language/baseline/compio-language-parser.ts && node scripts/patch-lezer-parser.mjs",
    "prepare": "husky",
    "deploy": "npm run build && wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.41.0",
    "@types/node": "25.6.2",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^9.39.1",
    "husky": "9.1.7",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.5",
    "workbox-window": "7.4.1",
    "wrangler": "^4.101.0"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.2",
    "@lezer/generator": "1.8.0",
    "codemirror": "6.0.2",
    "convert": "7.0.0",
    "convert-units": "3.0.0-beta.8",
    "decimal.js": "10.6.0",
    "lezer": "0.13.5"
  }
}
