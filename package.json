{
  "name": "calculus",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "preview": "vite preview",
    "test": "vitest run",
    "bench": "vitest bench src/benchmarks",
    "test:watch": "vitest",
    "grammar": "lezer-generator ./src/language/baseline/calculus-language.grammar -o ./src/language/baseline/calculus-language.ts",
    "grammar-inline-units": "node --experimental-strip-types scripts/generate-inline-units-lezer.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "25.6.2",
    "husky": "9.1.7",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.5",
    "workbox-window": "7.4.1"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.2",
    "@lezer/generator": "1.8.0",
    "codemirror": "6.0.2",
    "convert": "7.0.0",
    "convert-units": "3.0.0-beta.8",
    "decimal.js": "10.6.0",
    "lezer": "0.13.5"
  }
}
